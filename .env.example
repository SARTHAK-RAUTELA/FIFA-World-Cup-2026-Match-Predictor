# Free API Keys - Register at these sites to get free keys

# football-data.org - Free registration at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_key_here

# API-Football via RapidAPI - 100 requests/day free at https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=your_rapidapi_key_here

# NewsAPI - 100 requests/day free at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# GNews - 100 requests/day free at https://gnews.io/
GNEWS_API_KEY=your_gnews_key_here

# TheSportsDB - Free tier uses key "3", Patreon members get personal key
SPORTS_DB_API_KEY=3

# AllSportsAPI - https://allsportsapi.com/
ALLSPORTS_API_KEY=your_allsports_key_here

# Settings
MIN_CONFIDENCE_THRESHOLD=93.0
DATA_REFRESH_INTERVAL=300
PRE_MATCH_REFRESH_INTERVAL=60
LINEUP_REFRESH_INTERVAL=120
MAX_GOALS_PREDICTION=8
HOME_ADVANTAGE_FACTOR=1.15
